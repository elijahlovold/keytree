# Generated by CMake at configure time — @ONLY substitution applied.
# Runs at install time (cmake --install). Installs the default config into
# the invoking user's XDG config dir, handling sudo correctly.

set(_src "@CMAKE_SOURCE_DIR@/example-config/config.toml")

# When invoked via sudo, SUDO_USER is the real user; resolve their home via
# getent so we don't install into /root/.config.
if(DEFINED ENV{SUDO_USER} AND NOT "$ENV{SUDO_USER}" STREQUAL "")
    execute_process(
        COMMAND getent passwd "$ENV{SUDO_USER}"
        OUTPUT_VARIABLE _passwd
        OUTPUT_STRIP_TRAILING_WHITESPACE
    )
    # passwd format: name:pw:uid:gid:gecos:home:shell — anchor full line so
    # REGEX REPLACE replaces the entire string, not just the matched suffix.
    string(REGEX REPLACE "^[^:]*:[^:]*:[^:]*:[^:]*:[^:]*:([^:]*):[^:]*$" "\\1" _home "${_passwd}")
else()
    set(_home "$ENV{HOME}")
endif()

# Respect XDG_CONFIG_HOME if the real user set it (sudo usually strips it,
# so this mainly matters for non-sudo installs).
if(DEFINED ENV{XDG_CONFIG_HOME} AND NOT "$ENV{XDG_CONFIG_HOME}" STREQUAL "")
    set(_cfg_base "$ENV{XDG_CONFIG_HOME}")
else()
    set(_cfg_base "${_home}/.config")
endif()

set(_keytree_dir "${_cfg_base}/keytree")
set(_dst         "${_keytree_dir}/config.toml")

if(EXISTS "${_cfg_base}")
    if(NOT EXISTS "${_keytree_dir}")
        file(MAKE_DIRECTORY "${_keytree_dir}")
        message(STATUS "keytree: created ${_keytree_dir}")
    endif()

    if(NOT EXISTS "${_dst}")
        file(COPY_FILE "${_src}" "${_dst}")
        message(STATUS "keytree: installed default config to ${_dst}")

        # Fix ownership so the file isn't owned by root when installed via sudo.
        if(DEFINED ENV{SUDO_UID} AND DEFINED ENV{SUDO_GID})
            execute_process(
                COMMAND chown "$ENV{SUDO_UID}:$ENV{SUDO_GID}"
                              "${_dst}" "${_keytree_dir}"
            )
        endif()
    else()
        message(STATUS "keytree: config already exists at ${_dst}, skipping")
    endif()
else()
    message(STATUS "keytree: ${_cfg_base} not found, skipping config install")
endif()
